# Nextcloud server URL (must use https://)
NEXTCLOUD_BASE_URL=https://your-nextcloud-instance.com

# Nextcloud username
NEXTCLOUD_USER=your_username

# App password / access token (generated in Nextcloud settings)
NEXTCLOUD_ACCESS_TOKEN=your_access_token

# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=20

# Folder name in Nextcloud News
NEWS_FOLDER="Your Folder Name"

# Feed name within the folder
NEWS_FEED="Your Feed Name"

# Number of days per output file (default: 7)
# Set to 1 for one file per day, 0 to disable splitting
DAYS_PER_FILE=7

# Output formats (comma-separated, default: md)
# Supported: md, md-inline, pdf, txt, json
# md           – Markdown with separate images/ directory (default)
# md-inline    – Markdown with base64-embedded images
# pdf          – PDF via WeasyPrint
# txt          – Plain text
# json         – Structured JSON
OUTPUT_FORMATS=md

# State tracking mode (default: mark_read)
# Controls how the fetcher tracks which items have been processed:
# none        – Always fetch all unread items, no state saved (pure stateless)
# file        – Save/load timestamp from .news-digest/state.json (legacy)
# mark_read   – Fetch all unread, then mark them as read on the server
#               (default — no state file needed, same items won't re-appear)
STATE_MODE=mark_read